# MongoDB
MONGODB_URL=mongodb://localhost:27017/grh

# Server
NEST_PORT=3001
FRONTEND_URLS=http://localhost:3000

# Redis
# Option 1: Full Redis URL (recommended for production with authentication)
# REDIS_URL=redis://default:password@host:port
# Option 2: Separate variables
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Log Aggregator
LOG_AGGREGATOR_ENABLED=true
LOG_AGGREGATOR_URL=http://localhost:3000/webhooks/logs
LOG_AGGREGATOR_SECRET=change_me
LOG_AGGREGATOR_APP_NAME=grh-backend
